<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The App Sandbox is intentionally disabled: Getman is sideloaded as an
	     unsigned .dmg via GitHub releases (not the App Store), and its in-app
	     auto-updater (updat) must download the installer and launch it with
	     `open`, which the sandbox blocks. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
